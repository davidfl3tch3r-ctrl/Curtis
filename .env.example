# ─────────────────────────────────────────────────────────────────────────────
# CURTIS — Environment Variables
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in values below (see guide for where to find each one)
# 3. NEVER commit .env.local to Git — it's in .gitignore already
# ─────────────────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────────────────
# Find at: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# ── API-FOOTBALL ──────────────────────────────────────────────────────────────
# Get free key at: dashboard.api-football.com (no credit card)
# Free tier: 100 requests/day — enough for development + small leagues
# Paid plans when you scale: https://www.api-football.com/pricing
API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY_HERE

# ── APP ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
